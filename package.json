{
  "name": "my-blog",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --port 3001",
    "build": "next build",
    "start": "next start",
    "lint": "npm run --silent lint:style; npm run --silent lint:es",
    "lint:es": "eslint 'app/**/*.{js,jsx,ts,tsx}'",
    "lint:es:fix": "eslint --fix 'app/**/*.{js,jsx,ts,tsx}'",
    "lint:style": "stylelint 'app/**/*.{css,less,sass,scss}'",
    "lint:style:fix": "stylelint --fix 'app/**/*.{css,less,sass,scss}'",
    "lint:fix": "npm run --silent lint:style:fix; npm run --silent lint:es:fix",
    "format": "prettier --write --loglevel=warn 'app/**/*.{js,jsx,ts,tsx,html,json,gql,graphql}'",
    "preinstall": "npx typesync || :",
    "prepare": "npx simple-git-hooks || :"
  },
  "dependencies": {
    "@next/third-parties": "^16.2.4",
    "@radix-ui/react-dropdown-menu": "^2.1.6",
    "@radix-ui/react-slot": "^1.1.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "highlight.js": "^11.11.0",
    "html-react-parser": "^5.1.15",
    "lucide-react": "^0.477.0",
    "microcms-js-sdk": "^3.1.2",
    "microcms-ts-sdk": "^1.2.0",
    "next": "14.2.35",
    "next-themes": "^0.4.6",
    "react": "^18",
    "react-dom": "^18",
    "tailwind-merge": "^3.0.2",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@eslint/compat": "^1.2.3",
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.15.0",
    "@tsconfig/strictest": "^2.0.5",
    "@types/eslint": "^9.6.1",
    "@types/eslint-config-prettier": "^6.11.3",
    "@types/eslint-plugin-jsx-a11y": "^6.9.0",
    "@types/eslint-plugin-tailwindcss": "^3.17.0",
    "@types/lint-staged": "^13.3.0",
    "@types/node": "^20",
    "@types/prettier": "^3.0.0",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@typescript-eslint/eslint-plugin": "^8.15.0",
    "@typescript-eslint/parser": "^8.15.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.15.0",
    "eslint-config-next": "^15.0.3",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.30.0",
    "eslint-plugin-jsx-a11y": "^6.10.0",
    "eslint-plugin-tailwindcss": "^3.17.4",
    "eslint-plugin-unused-imports": "^4.1.3",
    "globals": "^15.12.0",
    "lint-staged": "^15.5.2",
    "postcss": "^8",
    "prettier": "^3.3.3",
    "simple-git-hooks": "^2.11.1",
    "stylelint": "^16.9.0",
    "stylelint-config-recess-order": "^5.1.0",
    "stylelint-config-standard": "^36.0.1",
    "stylelint-order": "^6.0.4",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
  },
  "lint-staged": {
    "app/**/*.{js,jsx,ts,tsx}": [
      "prettier --write --loglevel=warn",
      "eslint --fix --quiet"
    ],
    "app/**/*.{css,less,sass,scss}": [
      "stylelint --fix --quiet"
    ],
    "app/**/*.{html,json,gql,graphql}": [
      "prettier --write --loglevel=error"
    ]
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged"
  }
}
